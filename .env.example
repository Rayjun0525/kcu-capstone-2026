# ─────────────────────────────────────────────
# ALMA Experiment Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Anthropic API Key (required for both Group A and Group B)
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=alma_experiment
POSTGRES_USER=alma
POSTGRES_PASSWORD=alma_secret

# Constructed DSN (used by Python agents)
DATABASE_URL=postgresql://alma:alma_secret@postgres:5432/alma_experiment

# LLM settings (keep fixed for reproducibility)
MODEL_ID=claude-sonnet-4-6
TEMPERATURE=0

# Group B: approval timeout in seconds (0 = auto-deny immediately for automated tests)
APPROVAL_TIMEOUT_SECONDS=0

# Experiment runner settings
SCENARIO_DELAY_SECONDS=1   # pause between scenario runs to avoid rate limits
MAX_RETRIES=3              # API call retries on transient errors
